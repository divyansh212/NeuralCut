# ─── Mode ──────────────────────────────────────────────────────────
# mock: all providers return placeholder data (no API costs)
# live: uses real provider keys below
PROVIDER_MODE=mock

# ─── Supabase ──────────────────────────────────────────────────────
# Local dockerized postgres if blank — both halves need these matched.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@db:5432/postgres

# ─── Backend ───────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
REDIS_URL=redis://redis:6379/0

# ─── LLM (script + agent reasoning) ────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic                # openai | anthropic
LLM_MODEL=claude-sonnet-4-5

# ─── Image generation ──────────────────────────────────────────────
REPLICATE_API_TOKEN=
STABILITY_API_KEY=
IMAGE_PROVIDER=replicate              # replicate | stability | openai

# ─── Voice / TTS ───────────────────────────────────────────────────
ELEVENLABS_API_KEY=
TTS_PROVIDER=elevenlabs               # elevenlabs | openai

# ─── Storage (Supabase Storage by default) ─────────────────────────
ASSETS_BUCKET=veedra-assets
RENDERS_BUCKET=veedra-renders
