# ---- NeuralCut env ---------------------------------------------------------
# Copy to .env (PowerShell:  Copy-Item .env.example .env) and fill in.

# mode: mock (no keys, placeholder generation) | live (real providers)
PROVIDER_MODE=mock

# Supabase ------------------------------------------------------------------
# Frontend gets URL + anon (safe to expose). Backend also gets service + jwt.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=
STORAGE_BUCKET=renders

# Infra ---------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=http://localhost:3000

# Live provider keys (only needed when PROVIDER_MODE=live) -------------------
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
ELEVENLABS_API_KEY=
# PyTorch image model (ImageLive). Default is SD 1.5; override if you like.
SD_MODEL_ID=runwayml/stable-diffusion-v1-5
SD_STEPS=25

# ---- Frontend (these go in frontend/.env.local, NOT here) -----------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
